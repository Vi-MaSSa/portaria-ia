<mxfile host="app.diagrams.net">
    <diagram id="Fase1SequenceDeviceServer" name="Fase 1 - Sequence Device Server">
        <mxGraphModel dx="1200" dy="1600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="1600" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="2" value="Device" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=16;" parent="1" vertex="1">
                    <mxGeometry x="120" y="40" width="200" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="3" value="Server\n(HTTPS + Express + WSS)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=16;" parent="1" vertex="1">
                    <mxGeometry x="640" y="40" width="260" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="4" value="1. POST /device/ticket\nHeaders: Content-Type: application/json\nBody: { deviceId, secret }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="120" y="140" width="240" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="5" value="2. validateDeviceMiddleware(req)\n- load device record\n- compare secret hash" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="640" y="140" width="260" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="6" value="3. jwt.sign({ deviceId, type:'device_ticket', iat, exp: now + 30s })" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="640" y="290" width="260" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="7" value="4. 200 OK\nBody: { token: JWT }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f9ec;strokeColor=#2f7a3b;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="120" y="430" width="240" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="8" value="5. Device inicia wss://server?token=JWT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="120" y="540" width="240" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="9" value="6. TLS handshake\n- ClientHello / ServerHello\n- certificate + finished\nsecure channel" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="640" y="540" width="260" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="10" value="7. HTTP Upgrade request\nHeaders: Connection: Upgrade, Upgrade: websocket, Sec-WebSocket-Key, Origin\nQuery: token=JWT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="120" y="680" width="240" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="11" value="8. extract token from req.url\n(token query param)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="640" y="690" width="260" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="12" value="9. jwt.verify(token, JWT_SECRET)\n- signature valida\n- exp não expirado\n- type:'device_ticket'\n- deviceId presente" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="640" y="820" width="260" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="13" value="10. Decision: token válido?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fcf4d6;strokeColor=#b78b00;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="390" y="970" width="180" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="14" value="11. Origin validation\n- req.headers.origin allowlist\n- previne CSWSH" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="640" y="980" width="260" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="15" value="12. Decision: origin permitido?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fcf4d6;strokeColor=#b78b00;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="930" y="980" width="180" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="16" value="13. close(1008, 'Invalid token')\nconn. encerrada" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffdede;strokeColor=#d32f2f;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="120" y="1110" width="240" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="17" value="14. close(1008, 'Bad Origin')\nconn. encerrada" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffdede;strokeColor=#d32f2f;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="640" y="1110" width="260" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="18" value="15. ws.deviceId = decoded.deviceId\nactiveConnections[deviceId] = ws" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f9ec;strokeColor=#2f7a3b;fontSize=12;" parent="1" vertex="1">
                    <mxGeometry x="640" y="1240" width="260" height="100" as="geometry"/>
